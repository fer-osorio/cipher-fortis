{
  "version": 4,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (ASan/UBSan)",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CIPHFORTIS_BUILD_TYPE": "debug"
      }
    },
    {
      "name": "test",
      "displayName": "Test (coverage)",
      "binaryDir": "${sourceDir}/build/test",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CIPHFORTIS_BUILD_TYPE": "test"
      }
    },
    {
      "name": "profile",
      "displayName": "Profile (gprof)",
      "binaryDir": "${sourceDir}/build/profile",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CIPHFORTIS_BUILD_TYPE": "profile"
      }
    },
    {
      "name": "release",
      "displayName": "Release (optimised)",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CIPHFORTIS_BUILD_TYPE": "release"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",   "configurePreset": "debug"   },
    { "name": "test",    "configurePreset": "test"    },
    { "name": "profile", "configurePreset": "profile" },
    { "name": "release", "configurePreset": "release" }
  ],
  "testPresets": [
    {
      "name": "test",
      "configurePreset": "test",
      "output": { "outputOnFailure": true }
    }
  ]
}
